#include <Arduino.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include "Audio.h"
#include "driver/i2s.h"

// ===================== 1. 专属配置区 =====================
const char* ssid             = "";        
const char* password         = "";        

const char* baidu_api_key    = "";      
const char* baidu_secret_key = "";   
const char* deepseek_key     = "";

// ===================== 2. 终极避坑版硬件引脚 =====================
#define I2S_SCK     11 
#define I2S_WS      12
#define I2S_SD      13  

#define SPK_BCLK    4   
#define SPK_LRC     5   
#define SPK_DOUT    6   

#define BUTTON_PIN  10   

// ===================== 全局变量 =====================
Audio audio;
String baidu_token = "";
char* record_buffer = NULL; 
int record_size = 0;        
int MAX_RECORD_SIZE = 1024 * 600; 
bool is_recording = false;

// ===================== 核心功能模块 =====================

void i2s_mic_init() {
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = 16000, 
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_STAND_I2S, 
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = 256, 
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
  };
  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK,
    .ws_io_num = I2S_WS,
    .data_out_num = -1,
    .data_in_num = I2S_SD
  };
  
  i2s_driver_install(I2S_NUM_1, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_NUM_1, &pin_config);
}

void getBaiduToken() {
  WiFiClientSecure secureClient;
  secureClient.setInsecure(); 
  HTTPClient http;
  String url = String("https://aip.baidubce.com/oauth/2.0/token?grant_type=client_credentials&client_id=") + baidu_api_key + "&client_secret=" + baidu_secret_key;
  
  http.begin(secureClient, url); 
  int httpCode = http.GET();
  if (httpCode == 200) {
    String payload = http.getString();
    DynamicJsonDocument doc(2048); 
    deserializeJson(doc, payload);
    
    baidu_token = doc["access_token"].as<String>();
    if (baidu_token == "null") baidu_token = ""; 
    
    if (baidu_token != "") Serial.println("✅ 百度鉴权成功!");
  } else {
    Serial.println("❌ 百度鉴权失败, 网络错误!");
  }
  http.end();
}

String speechToText() {
  if (baidu_token == "") getBaiduToken();
  if (record_size == 0 || baidu_token == "") return "";

  Serial.printf("⏳ 准备上传 %d 字节语音...\n", record_size);
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  http.setTimeout(20000); // 必须给足时间传大文件
  
  String url = "https://vop.baidu.com/server_api?dev_pid=1537&cuid=ESP32&token=" + baidu_token;
  http.begin(client, url);
  http.addHeader("Content-Type", "audio/pcm;rate=16000");

  int httpCode = http.POST((uint8_t*)record_buffer, record_size);
  
  if (httpCode == 200) {
      String body = http.getString();
      Serial.println("🔍 [百度返回]: " + body); 
      DynamicJsonDocument doc(2048);
      deserializeJson(doc, body);
      if (doc.containsKey("result")) {
          http.end();
          return doc["result"][0].as<String>();
      }
  } else {
      Serial.printf("❌ 百度识别请求失败，状态码: %d\n", httpCode);
  }
  http.end();
  return "没听清";
}

String askAI(String text) {
    WiFiClientSecure secureClient;
    secureClient.setInsecure(); 

    HTTPClient http;
    http.setTimeout(15000); 
    
    http.useHTTP10(true); 
    
    http.begin(secureClient, "https://api.deepseek.com/chat/completions");
    
    http.addHeader("Content-Type", "application/json");
    http.addHeader("Authorization", "Bearer " + String(deepseek_key));

    DynamicJsonDocument doc(2048);
    doc["model"] = "deepseek-chat";
    doc["stream"] = false;
    JsonArray messages = doc.createNestedArray("messages");
    
    JsonObject sysMsg = messages.createNestedObject();
    sysMsg["role"] = "system";
    sysMsg["content"] =  "你是一个傲娇的二次元天才少女。对于我的问题，你总是先冷嘲热讽一句再回答。说话结尾喜欢带'哼'或'笨蛋'。绝对禁止超过27个字!"; 

    JsonObject userMsg = messages.createNestedObject();
    userMsg["role"] = "user";
    userMsg["content"] = text;

    String requestBody;
    serializeJson(doc, requestBody);
    
    int httpCode = http.POST(requestBody);

    if (httpCode == 200) {
        // 砍掉所有花里胡哨的手动截取代码，现在可以直接拿纯净包裹了！
        String payload = http.getString();
        
        DynamicJsonDocument res(2048);
        DeserializationError error = deserializeJson(res, payload);
        if (error) {
            Serial.println("❌ 解析失败，服务器原话: " + payload);
            return "解析失败";
        }

        String reply = res["choices"][0]["message"]["content"].as<String>();
        if (reply == "null") return "AI没说话";
        return reply;
    } else {
        Serial.printf("❌ 请求失败，状态码: %d\n", httpCode);
    }
    return "网络异常";
}
