// ==============================================================
void setup() {
  Serial.begin(115200);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  record_buffer = (char*)ps_malloc(MAX_RECORD_SIZE); 
  if (record_buffer == NULL) {
      Serial.println("⚠️ 警告：未检测到 PSRAM 或分配失败！强制降级...");
      MAX_RECORD_SIZE = 1024 * 100; 
      record_buffer = (char*)malloc(MAX_RECORD_SIZE);
      if (record_buffer == NULL) {
          Serial.println("❌ 致命错误：普通内存也分配失败！");
          while (true) { delay(1000); }
      }
  }

  WiFi.begin(ssid, password);
  Serial.print("\n正在连接 WiFi");
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\n✅ WiFi 连接成功!");

  audio.setPinout(SPK_BCLK, SPK_LRC, SPK_DOUT);
  audio.setVolume(100); 
  audio.setConnectionTimeout(1000, 2000);

  i2s_mic_init();
  getBaiduToken();
  
  Serial.println("=================================================");
  Serial.println("✅ 返璞归真版系统全部就绪！快按键录音吧！");
  Serial.println("=================================================");
}

void loop() {
  audio.loop(); 

  if (digitalRead(BUTTON_PIN) == LOW) {
    if (!is_recording) {
      is_recording = true;
      record_size = 0;
      audio.stopSong(); 
      Serial.println("\n🎙️ [录音中...] 请说话！");
      
      // 过滤开头杂音
      size_t dummy_bytes;
      i2s_read(I2S_NUM_1, record_buffer, 2048, &dummy_bytes, 100); 
    }
    
    if (record_size < MAX_RECORD_SIZE - 1024) {
      size_t bytes_read = 0;
      i2s_read(I2S_NUM_1, record_buffer + record_size, 1024, &bytes_read, 100);
      if (bytes_read > 0) record_size += bytes_read;
    }
  } 
  else { 
    if (is_recording) {
      is_recording = false;
      Serial.printf("\n⏹️ [录音结束]，录制了 %d 字节...\n", record_size);

      if (record_size > 8000) { 
        Serial.println("\n[1/3] 上传百度识别...");
        String text = speechToText();
        Serial.println("🗣️ 识别结果: " + text);

        if (text != "没听清" && text != "" && text != "网络连接失败") {
          Serial.println("\n[2/3] 呼叫 DeepSeek...");
          String reply = askAI(text);
          Serial.println("🤖 AI 回复: " + reply);

          if (reply != "解析失败" && reply != "网络异常" && reply != "AI没说话") {
            Serial.println("\n[3/3] 请求语音合成...");
            String urlEncoded = "";
            for (int i = 0; i < reply.length(); i++) {
                 if (isalnum((unsigned char)reply[i])) {
                     urlEncoded += reply[i];
                 } else {
                     String hex = String((uint8_t)reply[i], HEX);
                     if (hex.length() < 2) hex = "0" + hex;
                     urlEncoded += "%" + hex;
                 }
            }
String tts = "http://tsn.baidu.com/text2audio?tex=" + urlEncoded + "&lan=zh&cuid=ESP32&ctp=1&tok=" + baidu_token + "&per=5";
            audio.connecttohost(tts.c_str());
          }
        }
      } else {
        Serial.println("❌ 录音太短，防误触机制已拦截。");
      }
    }
  }
}
